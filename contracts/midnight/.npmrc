# npm on Windows always shells out to cmd.exe for package.json scripts by
# default (a documented npm quirk based on process.platform) — true even
# when npm is invoked from WSL bash, because no native Linux Node/npm is
# installed in WSL here; `which npm` resolves to the Windows npm mounted at
# /mnt/c/Program Files/nodejs, so it's still a Windows process underneath.
# The `compile` script below uses bash syntax (for loops, ||, grep), which
# cmd.exe cannot parse at all ("f was unexpected at this time."). Forcing
# bash here fixes that syntax error and makes the script's own PATH-guard
# (see package.json's `compile` script) run and report cleanly instead of
# crashing with a cmd.exe parse error, from both Git Bash and WSL.
#
# Known residual limitation: this does NOT make `npm test` fully
# self-sufficient end-to-end. The bash spawned by Windows npm resolves via
# Windows PATH (Git Bash/MSYS), which cannot see WSL's
# /home/jinx/.local/bin/compact — so the guard will correctly, loudly fail
# with instructions rather than silently passing, but `npm run compile`
# itself still cannot succeed without a native Linux Node/npm inside WSL
# (a system-level install, out of scope here). Until then, the real
# working test workflow is two separate steps: (1) compile via WSL directly
# — `wsl.exe -e bash -lc "cd <path> && for f in bonding_curve
# eligibility_gate treasury creator_escrow vesting lp_escrow cto_governance;
# do compact compile --skip-zk \"$f.compact\" \"compiled/$f\"; done"` (no
# `darkveil` — it was retired and merged into eligibility_gate.compact/
# bonding_curve.compact, Phase 2, 2026-07-11) —
# then (2) `npx vitest run` from Git Bash/native, which needs only the
# already-compiled JS output and @midnight-ntwrk/compact-runtime, not the
# `compact` CLI itself.
script-shell=bash
